@model Warehouse.Models.DTOs.ProductDto
@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Product Details</h1>
        <p class="text-muted mb-0">Detailed catalog information for product sku @Model.SKU</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <span class="fw-semibold">Product Specifications</span>
            </div>
            <div class="card-body">
                <table class="table table-bordered mb-0" style="border-collapse: separate; border-spacing: 0;">
                    <tbody>
                        <tr>
                            <td class="fw-semibold text-muted" style="width: 35%; background-color: #F8FAFC;">Product Name</td>
                            <td><strong>@Model.Name</strong></td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">SKU Code</td>
                            <td>
                                <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">
                                    @Model.SKU
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Category</td>
                            <td>@(Model.CategoryName ?? "—")</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Unit Price</td>
                            <td class="fw-bold text-primary">@Model.UnitPrice.ToString("C")</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Description</td>
                            <td class="text-muted">@(Model.Description ?? "No description provided.")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i data-lucide="edit" style="width: 16px; height: 16px;"></i> Edit Product
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i> Delete Product
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
