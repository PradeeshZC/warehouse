@model Warehouse.Models.DTOs.ProductDto
@{
    ViewData["Title"] = "Edit Product";
}

<h1 class="h2 mb-4">Edit Product</h1>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label for="Name" class="form-label">Name <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" required maxlength="300" />
                <span class="text-danger" data-valmsg-for="Name"></span>
            </div>

            <div class="mb-3">
                <label for="SKU" class="form-label">SKU <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="SKU" name="SKU" value="@Model.SKU" required maxlength="100" />
                <span class="text-danger" data-valmsg-for="SKU"></span>
            </div>

            <div class="mb-3">
                <label for="Description" class="form-label">Description</label>
                <textarea class="form-control" id="Description" name="Description" rows="3" maxlength="2000">@Model.Description</textarea>
            </div>

            <div class="mb-3">
                <label for="UnitPrice" class="form-label">Unit Price <span class="text-danger">*</span></label>
                <input type="number" class="form-control" id="UnitPrice" name="UnitPrice" step="0.01" min="0" value="@Model.UnitPrice" required />
            </div>

            <div class="mb-3">
                <label for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                <select class="form-select" id="CategoryId" name="CategoryId" required asp-items="@(ViewBag.Categories as SelectList)">
                    <option value="">— Select Category —</option>
                </select>
                <span class="text-danger" data-valmsg-for="CategoryId"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
