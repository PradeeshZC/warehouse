@{
    ViewData["Title"] = "Create Product";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Create Product</h1>
        <p class="text-muted mb-0">Add a new product to the catalog. Optionally set initial inventory.</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i data-lucide="arrow-left" style="width:16px;height:16px;"></i> Back to Catalog
    </a>
</div>

<div class="row">
    <div class="col-lg-9">
        <form asp-action="Create" method="post" id="createProductForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

            <!-- ── Product Information ── -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2">
                    <i data-lucide="package" style="width:16px;height:16px;color:#2563EB;"></i>
                    <span class="fw-semibold">Product Information</span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="Name" class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="Name" name="Name" required maxlength="300"
                                   placeholder="e.g. Industrial Pallet Wrapper" />
                            <span class="text-danger" data-valmsg-for="Name"></span>
                        </div>

                        <div class="col-md-3">
                            <label for="SKU" class="form-label">SKU Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="SKU" name="SKU" required maxlength="100"
                                   placeholder="e.g. WH-PL-WRAP-01" />
                            <span class="text-danger" data-valmsg-for="SKU"></span>
                        </div>

                        <div class="col-md-3">
                            <label for="Barcode" class="form-label">
                                Barcode
                                <span class="text-muted" style="font-size:11px;">(optional, unique)</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-white text-muted">
                                    <i data-lucide="scan-line" style="width:14px;height:14px;"></i>
                                </span>
                                <input type="text" class="form-control" id="Barcode" name="Barcode" maxlength="100"
                                       placeholder="EAN-13, UPC, QR..." />
                            </div>
                            <span class="text-danger" data-valmsg-for="Barcode"></span>
                        </div>

                        <div class="col-md-6">
                            <label for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                            <select class="form-select" id="CategoryId" name="CategoryId" required
                                    asp-items="@(ViewBag.Categories as SelectList)">
                                <option value="">— Select Category —</option>
                            </select>
                            <span class="text-danger" data-valmsg-for="CategoryId"></span>
                        </div>

                        <div class="col-md-6">
                            <label for="UnitPrice" class="form-label">Unit Price <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input type="number" class="form-control" id="UnitPrice" name="UnitPrice"
                                       step="0.01" min="0" required placeholder="0.00" />
                            </div>
                            <span class="text-danger" data-valmsg-for="UnitPrice"></span>
                        </div>

                        <div class="col-12">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" name="Description" rows="3"
                                      maxlength="2000"
                                      placeholder="Enter specifications, dimensions, packaging details..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Initial Inventory (Optional) ── -->
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center gap-2 justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <i data-lucide="warehouse" style="width:16px;height:16px;color:#16A34A;"></i>
                        <span class="fw-semibold">Initial Inventory</span>
                        <span class="badge bg-secondary" style="font-size:11px;">Optional</span>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="toggleInventory" />
                        <label class="form-check-label text-muted" for="toggleInventory" style="font-size:13px;">Set initial stock</label>
                    </div>
                </div>
                <div class="card-body" id="inventorySection" style="display:none;">
                    <p class="text-muted mb-3" style="font-size:13px;">
                        Providing an initial quantity will automatically create an inventory stock record and a <strong>StockIn</strong> transaction.
                    </p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="InitialQuantity" class="form-label">Initial Quantity</label>
                            <input type="number" class="form-control" id="InitialQuantity" name="InitialQuantity"
                                   step="0.01" min="0.01" placeholder="e.g. 100" />
                            <span class="text-danger" data-valmsg-for="InitialQuantity"></span>
                        </div>

                        <div class="col-md-4">
                            <label for="WarehouseEntityId" class="form-label">Warehouse <span class="text-danger" id="whRequired" style="display:none;">*</span></label>
                            <select class="form-select" id="WarehouseEntityId" name="WarehouseEntityId"
                                    asp-items="@(ViewBag.Warehouses as SelectList)">
                                <option value="">— Select Warehouse —</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label for="BinId" class="form-label">Bin Location <span class="text-muted" style="font-size:11px;">(optional)</span></label>
                            <select class="form-select" id="BinId" name="BinId" disabled>
                                <option value="">— Select Bin —</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="plus" style="width:16px;height:16px;"></i> Create Product
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            lucide.createIcons();

            // Toggle initial inventory section
            $('#toggleInventory').change(function () {
                if ($(this).is(':checked')) {
                    $('#inventorySection').slideDown();
                    $('#whRequired').show();
                } else {
                    $('#inventorySection').slideUp();
                    $('#whRequired').hide();
                    $('#InitialQuantity').val('');
                    $('#WarehouseEntityId').val('');
                    $('#BinId').html('<option value="">— Select Bin —</option>').prop('disabled', true);
                }
            });

            // Load bins when warehouse selected
            $('#WarehouseEntityId').change(function () {
                var wid = $(this).val();
                var $bin = $('#BinId');
                $bin.html('<option value="">— Select Bin —</option>').prop('disabled', true);
                if (!wid) return;
                $.get('/Inventory/GetBinsForWarehouse', { warehouseId: wid }, function (data) {
                    if (data && data.length > 0) {
                        $.each(data, function (i, b) { $bin.append($('<option>', { value: b.id, text: b.code })); });
                        $bin.prop('disabled', false);
                    }
                });
            });

            // Barcode scanner: auto-detect scan (fast input = barcode)
            var barcodeBuffer = '', barcodeTimer;
            $('#Barcode').on('keydown', function (e) {
                clearTimeout(barcodeTimer);
                if (e.key === 'Enter') {
                    e.preventDefault(); // prevent form submit on scanner Enter
                    $(this).trigger('change');
                    return;
                }
                barcodeTimer = setTimeout(function () { barcodeBuffer = ''; }, 100);
            });

            // Validate: if initial qty set, warehouse must be selected
            $('#createProductForm').on('submit', function (e) {
                var initQty = parseFloat($('#InitialQuantity').val()) || 0;
                if (initQty > 0 && !$('#WarehouseEntityId').val()) {
                    e.preventDefault();
                    alert('Please select a Warehouse for the initial inventory.');
                    $('#WarehouseEntityId').focus();
                }
            });
        });
    </script>
}
