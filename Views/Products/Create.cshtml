@{
    ViewData["Title"] = "Create Product";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Create Product</h1>
        <p class="text-muted mb-0">Add a new product to the catalog catalog registry</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to Catalog
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <span class="fw-semibold">Product Information</span>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="Name" class="form-label">Product Name<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="Name" name="Name" required maxlength="300" placeholder="e.g. Industrial Pallet Wrapper" />
                            <span class="text-danger" data-valmsg-for="Name"></span>
                        </div>

                        <div class="col-md-6">
                            <label for="SKU" class="form-label">SKU Code<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="SKU" name="SKU" required maxlength="100" placeholder="e.g. WH-PL-WRAP-01" />
                            <span class="text-danger" data-valmsg-for="SKU"></span>
                        </div>

                        <div class="col-md-6">
                            <label for="CategoryId" class="form-label">Category<span class="required-star">*</span></label>
                            <select class="form-select" id="CategoryId" name="CategoryId" required asp-items="@(ViewBag.Categories as SelectList)">
                                <option value="">— Select Category —</option>
                            </select>
                            <span class="text-danger" data-valmsg-for="CategoryId"></span>
                        </div>

                        <div class="col-md-6">
                            <label for="UnitPrice" class="form-label">Unit Price<span class="required-star">*</span></label>
                            <input type="number" class="form-control" id="UnitPrice" name="UnitPrice" step="0.01" min="0" required placeholder="0.00" />
                            <span class="text-danger" data-valmsg-for="UnitPrice"></span>
                        </div>

                        <div class="col-12">
                            <label for="Description" class="form-label">Description</label>
                            <textarea class="form-control" id="Description" name="Description" rows="4" maxlength="2000" placeholder="Enter detailed specifications, dimensions, packaging details, etc."></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3 mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i data-lucide="plus" style="width: 16px; height: 16px;"></i> Create Product
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
