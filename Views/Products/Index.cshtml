@model IEnumerable<Warehouse.Models.DTOs.ProductDto>
@{
    ViewData["Title"] = "Products";
    var search      = ViewBag.Search as string;
    int? categoryId = ViewBag.CategoryId as int?;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages  = ViewBag.TotalPages ?? 1;
    int totalCount  = ViewBag.TotalCount ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Products Catalog</h1>
        <p class="text-muted mb-0">View and manage catalog products, SKUs, barcodes and pricing</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i data-lucide="plus-circle" style="width:16px;height:16px;"></i> Add Product
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="check-circle-2" style="width:16px;height:16px;color:#16A34A;"></i>
            <span>@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width:16px;height:16px;color:#DC2626;"></i>
            <span>@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search & Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" id="productFilterForm" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="search" class="form-label">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted">
                        <i data-lucide="search" style="width:14px;height:14px;"></i>
                    </span>
                    <input type="text" id="search" name="search" class="form-control border-start-0 ps-0"
                           placeholder="Name, SKU or Barcode..." value="@search" />
                </div>
            </div>
            <div class="col-md-3">
                <label for="categoryId" class="form-label">Category</label>
                <select id="categoryId" name="categoryId" class="form-select" asp-items="@(ViewBag.Categories as SelectList)">
                    <option value="">— All Categories —</option>
                </select>
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i data-lucide="filter" style="width:14px;height:14px;"></i> Apply
                </button>
                <a asp-action="Index" class="btn btn-secondary flex-fill">
                    <i data-lucide="x" style="width:14px;height:14px;"></i> Clear
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Products Catalog</span>
        <span class="text-muted" style="font-size:13px;">
            @totalCount.ToString("N0") product(s) — page @currentPage of @totalPages
        </span>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive" style="border:none;border-radius:0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Barcode</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th class="text-end">Unit Price</th>
                            <th style="width:220px; text-align:right; padding-right:20px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge" style="background:#F1F5F9;color:#475569;border:1px solid #E2E8F0;font-size:12px;">@item.SKU</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <code style="font-size:12px;" title="Barcode">@item.Barcode</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted" style="font-size:12px;">—</span>
                                    }
                                </td>
                                <td><strong>@item.Name</strong></td>
                                <td>@(item.CategoryName ?? "—")</td>
                                <td class="text-end fw-bold">@item.UnitPrice.ToString("C")</td>
                                <td style="text-align:right;padding-right:20px;">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="eye" style="width:13px;height:13px;"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="edit-2" style="width:13px;height:13px;"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                            <i data-lucide="trash-2" style="width:13px;height:13px;"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state py-5">
                <i data-lucide="package-search" class="empty-state-icon"></i>
                <div class="empty-state-title">No products found</div>
                <p class="empty-state-desc">No products matched your search. Try different keywords or clear filters.</p>
            </div>
        }
    </div>
</div>

@await Html.PartialAsync("_PaginationPartial")

@section Scripts {
    <script>
        $(document).ready(function () {
            lucide.createIcons();
            $('#search').on('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); $('#productFilterForm').submit(); }
            });
            $('#categoryId').change(function () { $('#productFilterForm').submit(); });
        });
    </script>
}
