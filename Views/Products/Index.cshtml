@model IEnumerable<Warehouse.Models.DTOs.ProductDto>
@{
    ViewData["Title"] = "Products";
    var search = ViewBag.Search as string;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Products Catalog</h1>
        <p class="text-muted mb-0">View and manage catalog products, SKUs, categories and pricing</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i data-lucide="plus-circle" style="width: 16px; height: 16px;"></i> Add Product
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="check-circle-2" style="width: 16px; height: 16px; color: #16A34A;"></i>
            <span>@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width: 16px; height: 16px; color: #DC2626;"></i>
            <span>@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" class="mb-4">
    <div class="input-group" style="max-width: 480px;">
        <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: #D0D5DD; height: 40px; display: flex; align-items: center;">
            <i data-lucide="search" style="width: 16px; height: 16px;"></i>
        </span>
        <input type="text" name="search" class="form-control border-start-0 ps-0" placeholder="Search by name or SKU..." value="@search" style="height: 40px;" />
        <button class="btn btn-secondary" type="submit" style="height: 40px;">Search</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn btn-danger ms-2" style="height: 40px; display: inline-flex; align-items: center; justify-content: center; border-radius: 6px;">Clear</a>
        }
    </div>
</form>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Products Catalog</span>
        <span class="text-muted" style="font-size: 13px;">Showing page @currentPage of @totalPages</span>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>SKU</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th class="text-end">Unit Price</th>
                            <th style="width: 280px; text-align: right; padding-right: 20px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">
                                        @item.SKU
                                    </span>
                                </td>
                                <td><strong>@item.Name</strong></td>
                                <td>@(item.CategoryName ?? "—")</td>
                                <td class="text-end fw-bold">@item.UnitPrice.ToString("C")</td>
                                <td style="text-align: right; padding-right: 20px;">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="eye" style="width: 14px; height: 14px;"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                            <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state py-5">
                <i data-lucide="package-search" class="empty-state-icon"></i>
                <div class="empty-state-title">No products found</div>
                <p class="empty-state-desc">There are no products in the catalog matching your search, or the catalog is empty.</p>
            </div>
        }
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="d-flex justify-content-center mt-3">
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")" style="margin: 0 2px;">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search"
                       style="border-radius: 6px; border: 1px solid #D0D5DD; color: @(i == currentPage ? "#FFF" : "#344054"); background-color: @(i == currentPage ? "#2563EB" : "#FFF"); padding: 8px 16px; font-size: 14px; font-weight: 500; text-decoration: none; transition: all 0.1s ease-in;">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
