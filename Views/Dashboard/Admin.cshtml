@model Warehouse.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ShowSearch"] = true;
}

<div class="mb-4 pb-2 border-bottom">
    <h1 class="page-title mb-1">Dashboard</h1>
    <p class="text-muted mb-0">Monitor inventory, orders and warehouse activity</p>
</div>

<!-- Group 1: Inventory Metrics -->
<h5 class="section-title mb-3" style="font-size: 16px !important; color: #475569; text-transform: uppercase; letter-spacing: 0.5px;">Inventory Metrics</h5>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Products</div>
                <div class="kpi-value">@Model.TotalProducts</div>
            </div>
            <div class="kpi-trend neutral">
                <i data-lucide="package" style="width: 14px; height: 14px;"></i> Total catalog items
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Categories</div>
                <div class="kpi-value">@Model.TotalCategories</div>
            </div>
            <div class="kpi-trend neutral">
                <i data-lucide="tag" style="width: 14px; height: 14px;"></i> Product categories
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Warehouses</div>
                <div class="kpi-value">@Model.TotalWarehouses</div>
            </div>
            <div class="kpi-trend neutral">
                <i data-lucide="building" style="width: 14px; height: 14px;"></i> Active storage locations
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Inventory Value</div>
                <div class="kpi-value" style="font-size: 24px !important;">@Model.TotalInventoryValue.ToString("C")</div>
            </div>
            <div class="kpi-trend up">
                <i data-lucide="trending-up" style="width: 14px; height: 14px;"></i> Current stock valuation
            </div>
        </div>
    </div>
</div>

<!-- Group 2: Operational Metrics -->
<h5 class="section-title mb-3" style="font-size: 16px !important; color: #475569; text-transform: uppercase; letter-spacing: 0.5px;">Operational Metrics</h5>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Total Orders</div>
                <div class="kpi-value">@Model.TotalOrders</div>
            </div>
            <div class="kpi-trend neutral">
                <i data-lucide="shopping-cart" style="width: 14px; height: 14px;"></i> Sales order registry
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Pending Orders</div>
                <div class="kpi-value">@Model.PendingOrdersCount</div>
            </div>
            <div class="kpi-trend @(Model.PendingOrdersCount > 0 ? "down" : "neutral")">
                <i data-lucide="clock" style="width: 14px; height: 14px;"></i> Awaiting processing
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Active Shipments</div>
                <div class="kpi-value">@Model.ActiveShipmentsCount</div>
            </div>
            <div class="kpi-trend neutral">
                <i data-lucide="truck" style="width: 14px; height: 14px;"></i> Shipments in transit
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div>
                <div class="kpi-label">Low Stock Alerts</div>
                <div class="kpi-value" style="color: @(Model.LowStockCount > 0 ? "#DC2626" : "inherit")">@Model.LowStockCount</div>
            </div>
            <div class="kpi-trend @(Model.LowStockCount > 0 ? "down" : "up")">
                <i data-lucide="alert-triangle" style="width: 14px; height: 14px;"></i> Items below threshold
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Orders -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Recent Orders</span>
                <span class="badge badge-info">@Model.ActiveShipmentsCount Active Shipments</span>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentOrders.Any())
                {
                    <div class="table-responsive" style="border: none; border-radius: 0;">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Order #</th>
                                    <th>Status</th>
                                    <th class="text-end">Amount</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.RecentOrders)
                                {
                                    <tr>
                                        <td><strong>@order.OrderNumber</strong></td>
                                        <td>
                                            @{
                                                var badgeClass = "badge-pending";
                                                if (order.Status.ToLower() == "delivered") badgeClass = "badge-delivered";
                                                else if (order.Status.ToLower() == "shipped" || order.Status.ToLower() == "intransit") badgeClass = "badge-shipped";
                                                else if (order.Status.ToLower() == "cancelled") badgeClass = "badge-cancelled";
                                            }
                                            <span class="badge @badgeClass">@order.Status</span>
                                        </td>
                                        <td class="text-end fw-bold">@order.TotalAmount.ToString("C")</td>
                                        <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i data-lucide="shopping-bag" class="empty-state-icon"></i>
                        <div class="empty-state-title">No orders found</div>
                        <p class="empty-state-desc">There are currently no sales orders logged in the system.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Low Stock Products -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <span>Low Stock Products</span>
            </div>
            <div class="card-body p-0">
                @if (Model.LowStockProducts.Any())
                {
                    <div class="table-responsive" style="border: none; border-radius: 0;">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>SKU</th>
                                    <th>Warehouse</th>
                                    <th class="text-end">Qty</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.LowStockProducts)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td><code>@item.SKU</code></td>
                                        <td>@item.WarehouseName</td>
                                        <td class="text-end fw-bold" style="color: @(item.Quantity < 5 ? "#DC2626" : "#F59E0B")">@item.Quantity.ToString("F0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i data-lucide="check-circle-2" class="empty-state-icon" style="color: #16A34A;"></i>
                        <div class="empty-state-title">No low-stock products</div>
                        <p class="empty-state-desc">All inventory levels are currently within healthy thresholds.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Transactions -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <span>Recent Inventory Transactions</span>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentTransactions.Any())
                {
                    <div class="table-responsive" style="border: none; border-radius: 0;">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Product</th>
                                    <th>Warehouse</th>
                                    <th>Type</th>
                                    <th class="text-end">Quantity</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in Model.RecentTransactions)
                                {
                                    <tr>
                                        <td>@tx.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                        <td><strong>@tx.ProductName</strong></td>
                                        <td>@tx.WarehouseName</td>
                                        <td>
                                            @{
                                                var txClass = "tx-adjust";
                                                var txName = tx.TransactionType.ToString();
                                                if (txName == "StockIn" || txName == "PurchaseReceive") txClass = "tx-in";
                                                else if (txName == "StockOut" || txName == "OrderDispatch") txClass = "tx-out";
                                                else if (txName == "Transfer") txClass = "tx-transfer";
                                            }
                                            <span class="tx-badge @txClass">@tx.TransactionType</span>
                                        </td>
                                        <td class="text-end fw-bold">@tx.Quantity.ToString("F2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i data-lucide="history" class="empty-state-icon"></i>
                        <div class="empty-state-title">No transactions yet</div>
                        <p class="empty-state-desc">Recent stock adjustment logs will be displayed here.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}