@model Warehouse.Models.Entities.WarehouseEntity

@{
    ViewData["Title"] = "Delete Warehouse";
    bool hasStock = ViewBag.HasStock ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1 text-danger">Delete Warehouse</h1>
        <p class="text-muted mb-0">Confirm deletion of warehouse site @Model.Name</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Cancel
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        @if (hasStock)
        {
            <div class="alert alert-danger mb-4" role="alert">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i data-lucide="x-circle" style="width: 20px; height: 20px; color: #DC2626; flex-shrink: 0;"></i>
                    <h6 class="alert-heading fw-semibold mb-0">Cannot Delete Warehouse</h6>
                </div>
                <p class="mb-0">
                    The warehouse <strong>@Model.Name</strong> currently contains active inventory stock items. 
                    You must transfer or adjust all stock levels to zero before this warehouse can be deleted.
                </p>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-secondary">Back to Warehouses</a>
                <a asp-controller="Inventory" asp-action="Index" class="btn btn-primary">
                    <i data-lucide="edit-3" style="width: 16px; height: 16px;"></i> View Inventory
                </a>
            </div>
        }
        else
        {
            <div class="alert alert-danger mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <i data-lucide="alert-triangle" style="width: 20px; height: 20px; color: #DC2626; flex-shrink: 0;"></i>
                    <span><strong>CRITICAL WARNING:</strong> Are you sure you want to delete this warehouse? This will soft-delete the warehouse and all its associated storage bins.</span>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <span class="fw-semibold text-danger">Warehouse Details to Delete</span>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <tbody>
                            <tr>
                                <td class="fw-semibold text-muted" style="width: 35%; background-color: #F8FAFC;">Warehouse Name</td>
                                <td><strong>@Model.Name</strong></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Location Location</td>
                                <td>@(Model.Location ?? "—")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i> Confirm Delete
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
