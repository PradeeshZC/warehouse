@model IEnumerable<Warehouse.Models.DTOs.WarehouseDto>

@{
    ViewData["Title"] = "Warehouses";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Warehouses</h1>
        <p class="text-muted mb-0">Manage physical storage warehouse sites, location info and storage bins</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i data-lucide="plus-circle" style="width: 16px; height: 16px;"></i> Create New Warehouse
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="check-circle-2" style="width: 16px; height: 16px; color: #16A34A;"></i>
            <span>@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width: 16px; height: 16px; color: #DC2626;"></i>
            <span>@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Warehouse Locations</span>
        <span class="text-muted" style="font-size: 13px;">Showing @Model.Count() warehouses</span>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Location</th>
                            <th>Bin Count</th>
                            <th class="text-end">Total Stock Qty</th>
                            <th style="width: 320px; text-align: right; padding-right: 20px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var warehouse in Model)
                        {
                            <tr>
                                <td><strong>@warehouse.Name</strong></td>
                                <td class="text-muted">@(warehouse.Location ?? "—")</td>
                                <td>
                                    <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">
                                        @warehouse.BinCount Bins
                                    </span>
                                </td>
                                <td class="text-end fw-bold text-primary">@warehouse.TotalStockQuantity.ToString("N0")</td>
                                <td style="text-align: right; padding-right: 20px;">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@warehouse.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="eye" style="width: 14px; height: 14px;"></i> Details & Bins
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@warehouse.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@warehouse.Id" class="btn btn-danger btn-sm">
                                            <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state py-5">
                <i data-lucide="building" class="empty-state-icon"></i>
                <div class="empty-state-title">No warehouses found</div>
                <p class="empty-state-desc">Create your first warehouse location to begin tracking stock layout.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
