@{
    ViewData["Title"] = "Create Category";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Create Category</h1>
        <p class="text-muted mb-0">Create a new category for grouping products in the catalog</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to Categories
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <span class="fw-semibold">Category Details</span>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="name" class="form-label">Category Name<span class="required-star">*</span></label>
                            <input type="text" class="form-control" id="name" name="name" required maxlength="200" placeholder="e.g. Storage & Organization" />
                            <span class="text-danger">@Html.ValidationMessage("Name")</span>
                        </div>

                        <div class="col-12">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" name="description" rows="4" maxlength="1000" placeholder="Describe what types of products belong to this category..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3 mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i data-lucide="plus" style="width: 16px; height: 16px;"></i> Create Category
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
