@model Warehouse.Models.DTOs.CategoryDto

@{
    ViewData["Title"] = "Delete Category";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1 text-danger">Delete Category</h1>
        <p class="text-muted mb-0">Confirm deletion of product category @Model.Name</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Cancel
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="alert alert-danger mb-4" role="alert">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="alert-triangle" style="width: 20px; height: 20px; color: #DC2626; flex-shrink: 0;"></i>
                <span><strong>CRITICAL WARNING:</strong> Are you sure you want to delete this category? This action is permanent and cannot be undone.</span>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <span class="fw-semibold text-danger">Category Details to Delete</span>
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <tbody>
                        <tr>
                            <td class="fw-semibold text-muted" style="width: 35%; background-color: #F8FAFC;">Category Name</td>
                            <td><strong>@Model.Name</strong></td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Description</td>
                            <td class="text-muted">@(Model.Description ?? "No description provided.")</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold text-muted" style="background-color: #F8FAFC;">Associated Products</td>
                            <td>
                                <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">
                                    @Model.ProductCount products
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">
                    <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i> Confirm Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
