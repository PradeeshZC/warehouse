@model IEnumerable<Warehouse.Models.DTOs.CategoryDto>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Product Categories</h1>
        <p class="text-muted mb-0">Manage catalog categories and grouping for inventory products</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary">
            <i data-lucide="plus-circle" style="width: 16px; height: 16px;"></i> Create New Category
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="check-circle-2" style="width: 16px; height: 16px; color: #16A34A;"></i>
            <span>@TempData["Success"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="alert-circle" style="width: 16px; height: 16px; color: #DC2626;"></i>
            <span>@TempData["Error"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Category registry</span>
        <span class="text-muted" style="font-size: 13px;">Showing @Model.Count() categories</span>
    </div>
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Product Count</th>
                            <th style="width: 200px; text-align: right; padding-right: 20px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td><strong>@category.Name</strong></td>
                                <td class="text-muted">@(category.Description ?? "—")</td>
                                <td>
                                    <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">
                                        @category.ProductCount products
                                    </span>
                                </td>
                                <td style="text-align: right; padding-right: 20px;">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-secondary btn-sm">
                                            <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">
                                            <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state py-5">
                <i data-lucide="tag" class="empty-state-icon"></i>
                <div class="empty-state-title">No categories found</div>
                <p class="empty-state-desc">Create your first product category to group products in the catalog.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
