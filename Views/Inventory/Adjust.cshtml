@{
    ViewData["Title"] = "Adjust Inventory";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Adjust Inventory</h1>
        <p class="text-muted mb-0">Record a stock adjustment, increase, decrease, or transfer inventory between locations</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to Inventory
        </a>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger" role="alert">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i data-lucide="alert-circle" style="width: 16px; height: 16px; color: #DC2626;"></i>
            <h6 class="alert-heading fw-semibold mb-0">Please correct the following errors:</h6>
        </div>
        <ul class="mb-0 ps-3">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <span class="fw-semibold">Stock Adjustment / Transfer Details</span>
            </div>
            <div class="card-body">
                <form asp-action="Adjust" method="post" id="adjustForm">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <!-- Product Selection -->
                        <div class="col-12">
                            <label for="productId" class="form-label">Product<span class="required-star">*</span></label>
                            <select name="productId" id="productId" class="form-select" required>
                                <option value="">-- Select Product --</option>
                                @if (ViewBag.Products != null)
                                {
                                    @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem item in ViewBag.Products)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Transaction Type -->
                        <div class="col-md-6">
                            <label for="transactionType" class="form-label">Transaction Type<span class="required-star">*</span></label>
                            <select name="transactionType" id="transactionType" class="form-select" required>
                                <option value="">-- Select Type --</option>
                                @if (ViewBag.TransactionTypes != null)
                                {
                                    @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem item in ViewBag.TransactionTypes)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Quantity -->
                        <div class="col-md-6">
                            <label for="quantity" class="form-label">Quantity<span class="required-star">*</span></label>
                            <input type="number" name="quantity" id="quantity" class="form-control"
                                   step="0.01" min="0.01" required placeholder="Enter quantity" />
                        </div>
                    </div>

                    <h5 class="section-title mt-4 mb-3" style="font-size: 15px !important; color: #475569;">Source Location</h5>
                    <div class="row g-3">
                        <!-- Warehouse -->
                        <div class="col-md-6">
                            <label for="warehouseEntityId" class="form-label">Warehouse<span class="required-star">*</span></label>
                            <select name="warehouseEntityId" id="warehouseEntityId" class="form-select" required>
                                <option value="">-- Select Warehouse --</option>
                                @if (ViewBag.Warehouses != null)
                                {
                                    @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem item in ViewBag.Warehouses)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Bin Location -->
                        <div class="col-md-6">
                            <label for="binId" class="form-label">Storage Bin</label>
                            <select name="binId" id="binId" class="form-select" disabled>
                                <option value="">-- Select Bin --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Destination Location Section (For Transfers Only) -->
                    <div id="destinationSection" style="display: none;">
                        <h5 class="section-title mt-4 mb-3" style="font-size: 15px !important; color: #16A34A;">Destination Location</h5>
                        <div class="row g-3">
                            <!-- Destination Warehouse -->
                            <div class="col-md-6">
                                <label for="destinationWarehouseEntityId" class="form-label">Destination Warehouse<span class="required-star">*</span></label>
                                <select name="destinationWarehouseEntityId" id="destinationWarehouseEntityId" class="form-select">
                                    <option value="">-- Select Warehouse --</option>
                                    @if (ViewBag.Warehouses != null)
                                    {
                                        @foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem item in ViewBag.Warehouses)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- Destination Bin -->
                            <div class="col-md-6">
                                <label for="destinationBinId" class="form-label">Destination Storage Bin</label>
                                <select name="destinationBinId" id="destinationBinId" class="form-select" disabled>
                                    <option value="">-- Select Bin --</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    <div class="mb-4 mt-4">
                        <label for="notes" class="form-label">Notes</label>
                        <textarea name="notes" id="notes" class="form-control" rows="3"
                                  placeholder="Optional notes describing this adjustment or transfer"></textarea>
                    </div>

                    <div class="d-flex gap-2 justify-content-end border-top pt-3">
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary" id="btnSubmit">
                            <i data-lucide="check" style="width: 16px; height: 16px;"></i> Submit Adjustment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            lucide.createIcons();

            // Toggle destination fields based on transaction type (Transfer = 2)
            $('#transactionType').change(function () {
                var type = $(this).val();
                if (type === "2") {
                    $('#destinationSection').slideDown();
                    $('#destinationWarehouseEntityId').prop('required', true);
                } else {
                    $('#destinationSection').slideUp();
                    $('#destinationWarehouseEntityId').prop('required', false).val('');
                    $('#destinationBinId').html('<option value="">-- Select Bin --</option>').prop('disabled', true);
                }
            });

            // AJAX call to load bins for a selected warehouse
            function loadBins(warehouseSelectId, binSelectId) {
                var warehouseId = $(warehouseSelectId).val();
                var $binSelect = $(binSelectId);

                // Reset bin select list
                $binSelect.html('<option value="">-- Select Bin --</option>');

                if (!warehouseId) {
                    $binSelect.prop('disabled', true);
                    return;
                }

                $.ajax({
                    url: '/Inventory/GetBinsForWarehouse',
                    type: 'GET',
                    data: { warehouseId: warehouseId },
                    success: function (data) {
                        if (data && data.length > 0) {
                            $.each(data, function (index, bin) {
                                $binSelect.append($('<option>', {
                                    value: bin.id,
                                    text: bin.code
                                }));
                            });
                            $binSelect.prop('disabled', false);
                        } else {
                            $binSelect.html('<option value="">-- No Bins Configured --</option>');
                            $binSelect.prop('disabled', true);
                        }
                    },
                    error: function () {
                        $binSelect.html('<option value="">-- Error Loading Bins --</option>');
                        $binSelect.prop('disabled', true);
                    }
                });
            }

            // Bind change events
            $('#warehouseEntityId').change(function () {
                loadBins('#warehouseEntityId', '#binId');
            });

            // AJAX call for destination warehouse bins
            $('#destinationWarehouseEntityId').change(function () {
                loadBins('#destinationWarehouseEntityId', '#destinationBinId');
            });

            // Prevent submitting source and destination as identical
            $('#adjustForm').submit(function (e) {
                var type = $('#transactionType').val();
                if (type === "2") {
                    var srcWh = $('#warehouseEntityId').val();
                    var destWh = $('#destinationWarehouseEntityId').val();
                    var srcBin = $('#binId').val();
                    var destBin = $('#destinationBinId').val();

                    if (srcWh === destWh && srcBin === destBin) {
                        alert("Error: Source and destination locations (Warehouse & Bin) cannot be identical.");
                        e.preventDefault();
                        return false;
                    }
                }
                return true;
            });
        });
    </script>
}
