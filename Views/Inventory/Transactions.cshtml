@model IEnumerable<Warehouse.Models.DTOs.InventoryTransactionDto>

@{
    ViewData["Title"] = "Transaction History";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Transaction History</h1>
        <p class="text-muted mb-0">View all historical inventory updates, transfers, adjustments, and dispatches</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-secondary">
            <i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i> Back to Inventory
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Transaction Logs</span>
        <span class="text-muted" style="font-size: 13px;">Showing @Model.Count() records</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state py-5">
                <i data-lucide="history" class="empty-state-icon"></i>
                <div class="empty-state-title">No transactions recorded yet</div>
                <p class="empty-state-desc">When inventory stock is added, removed, adjusted, or transferred, the logs will appear here.</p>
            </div>
        }
        else
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>Warehouse</th>
                            <th>Type</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Previous</th>
                            <th class="text-end">New</th>
                            <th>Reference</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var txn in Model)
                        {
                            <tr>
                                <td>@txn.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><strong>@txn.ProductName</strong></td>
                                <td>@txn.WarehouseName</td>
                                <td>
                                    @{
                                        var txClass = "tx-adjust";
                                        var txName = txn.TransactionType.ToString();
                                        if (txName == "StockIn" || txName == "PurchaseReceive") txClass = "tx-in";
                                        else if (txName == "StockOut" || txName == "OrderDispatch") txClass = "tx-out";
                                        else if (txName == "Transfer") txClass = "tx-transfer";
                                    }
                                    <span class="tx-badge @txClass">@txn.TransactionType</span>
                                </td>
                                <td class="text-end fw-bold">@txn.Quantity.ToString("N0")</td>
                                <td class="text-end text-muted">@txn.PreviousQuantity.ToString("N0")</td>
                                <td class="text-end fw-medium">@txn.NewQuantity.ToString("N0")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(txn.ReferenceNumber))
                                    {
                                        <code>@txn.ReferenceNumber</code>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-muted" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@txn.Notes">
                                    @(txn.Notes ?? "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            lucide.createIcons();
        });
    </script>
}
