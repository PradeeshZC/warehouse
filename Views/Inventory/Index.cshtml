@model IEnumerable<Warehouse.Models.DTOs.InventoryStockDto>

@{
    ViewData["Title"] = "Inventory Stock Levels";
    var selectedWarehouseId = ViewBag.WarehouseId as int?;
    var selectedBinId = ViewBag.BinId as int?;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Actions and Filters Bar -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light">
        <form method="get" id="filterForm" class="row g-3 align-items-end">
            <!-- Warehouse Filter -->
            <div class="col-md-4">
                <label for="warehouseId" class="form-label fw-bold">Select Warehouse</label>
                <select id="warehouseId" name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
                    <option value="">-- All Warehouses --</option>
                </select>
            </div>

            <!-- Bin Filter -->
            <div class="col-md-4">
                <label for="binId" class="form-label fw-bold">Select Bin Location</label>
                <select id="binId" name="binId" class="form-select" asp-items="ViewBag.Bins" disabled="@(selectedWarehouseId == null || selectedWarehouseId == 0)">
                    <option value="">-- All Bins --</option>
                </select>
            </div>

            <!-- Filter Buttons -->
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-50">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary w-50">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Stock Levels</h4>
    <div>
        <a asp-action="Transactions" class="btn btn-outline-secondary">
            <i class="bi bi-clock-history"></i> Transaction History
        </a>
        <a asp-action="Adjust" class="btn btn-primary ms-2">
            <i class="bi bi-pencil-square"></i> Adjust Stock
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Product</th>
                <th>SKU</th>
                <th>Warehouse</th>
                <th>Bin Location</th>
                <th class="text-end">Quantity</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No inventory stock records found matching filters.</td>
                </tr>
            }
            else
            {
                @foreach (var stock in Model)
                {
                    <tr class="@(stock.Quantity < 10 ? "table-danger" : "")">
                        <td><strong>@stock.ProductName</strong></td>
                        <td><code>@stock.ProductSKU</code></td>
                        <td>@stock.WarehouseName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(stock.BinCode))
                            {
                                <span class="badge bg-secondary">@stock.BinCode</span>
                            }
                            else
                            {
                                <span class="text-muted">Unassigned</span>
                            }
                        </td>
                        <td class="text-end">
                            <span class="@(stock.Quantity < 10 ? "fw-bold text-danger fs-5" : "fs-5")">
                                @stock.Quantity.ToString("N2")
                            </span>
                            @if (stock.Quantity < 10)
                            {
                                <span class="badge bg-danger ms-1">Low Stock</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Auto submit when changing warehouse (clears selected bin since bins change)
            $('#warehouseId').change(function () {
                $('#binId').val(''); // Reset bin selection
                $('#filterForm').submit();
            });

            // Auto submit when changing bin
            $('#binId').change(function () {
                $('#filterForm').submit();
            });
        });
    </script>
}
