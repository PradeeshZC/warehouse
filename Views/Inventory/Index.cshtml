@model IEnumerable<Warehouse.Models.DTOs.InventoryStockDto>

@{
    ViewData["Title"] = "Inventory Stock Levels";
    var selectedWarehouseId = ViewBag.WarehouseId as int?;
    var selectedBinId = ViewBag.BinId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <div>
        <h1 class="page-title mb-1">Inventory Stock Levels</h1>
        <p class="text-muted mb-0">View and manage real-time inventory levels across warehouses and bins</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Transactions" class="btn btn-secondary">
            <i data-lucide="history" style="width: 16px; height: 16px;"></i> Transaction History
        </a>
        <a asp-action="Adjust" class="btn btn-primary">
            <i data-lucide="edit" style="width: 16px; height: 16px;"></i> Adjust Stock
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <div class="d-flex align-items-center gap-2">
            <i data-lucide="check-circle-2" style="width: 16px; height: 16px; color: #16A34A;"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Filters Bar -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" id="filterForm" class="row g-3 align-items-end">
            <!-- Warehouse Filter -->
            <div class="col-md-4">
                <label for="warehouseId" class="form-label">Select Warehouse</label>
                <select id="warehouseId" name="warehouseId" class="form-select" asp-items="ViewBag.Warehouses">
                    <option value="">-- All Warehouses --</option>
                </select>
            </div>

            <!-- Bin Filter -->
            <div class="col-md-4">
                <label for="binId" class="form-label">Select Bin Location</label>
                <select id="binId" name="binId" class="form-select" asp-items="ViewBag.Bins" disabled="@(selectedWarehouseId == null || selectedWarehouseId == 0)">
                    <option value="">-- All Bins --</option>
                </select>
            </div>

            <!-- Filter Buttons -->
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-50">
                    <i data-lucide="filter" style="width: 16px; height: 16px;"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-secondary w-50">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Stock Levels</span>
        <span class="text-muted" style="font-size: 13px;">Showing @Model.Count() records</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state py-5">
                <i data-lucide="package-x" class="empty-state-icon"></i>
                <div class="empty-state-title">No stock records found</div>
                <p class="empty-state-desc">No inventory stock records matched the selected warehouse or bin filters.</p>
            </div>
        }
        else
        {
            <div class="table-responsive" style="border: none; border-radius: 0;">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>SKU</th>
                            <th>Warehouse</th>
                            <th>Bin Location</th>
                            <th class="text-end">Quantity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stock in Model)
                        {
                            <tr style="@(stock.Quantity < 10 ? "background-color: #FEF2F2;" : "")">
                                <td><strong>@stock.ProductName</strong></td>
                                <td><code>@stock.ProductSKU</code></td>
                                <td>@stock.WarehouseName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(stock.BinCode))
                                    {
                                        <span class="badge text-secondary" style="background-color: #F1F5F9; color: #475569 !important; border: 1px solid #E2E8F0;">@stock.BinCode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <span class="@(stock.Quantity < 10 ? "fw-bold text-danger" : "fw-medium")">
                                        @stock.Quantity.ToString("N0")
                                    </span>
                                    @if (stock.Quantity < 10)
                                    {
                                        <span class="badge badge-danger ms-2" style="font-size: 11px; padding: 2px 6px;">Low Stock</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            lucide.createIcons();

            // Auto submit when changing warehouse (clears selected bin since bins change)
            $('#warehouseId').change(function () {
                $('#binId').val(''); // Reset bin selection
                $('#filterForm').submit();
            });

            // Auto submit when changing bin
            $('#binId').change(function () {
                $('#filterForm').submit();
            });
        });
    </script>
}
